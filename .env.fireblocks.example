# Fireblocks API credentials
FIREBLOCKS_API_KEY=your-fireblocks-api-key
FIREBLOCKS_API_PRIVATE_KEY_PATH=/path/to/fireblocks-secret.key

# Blockchain network chain ID (e.g. 11155111 for Sepolia)
FIREBLOCKS_CHAIN_ID=11155111

# Optional: defaults to production. Use https://sandbox-api.fireblocks.io for sandbox.
# FIREBLOCKS_API_BASE_URL=https://sandbox-api.fireblocks.io

# Fireblocks vault account used for signing transactions
FIREBLOCKS_VAULT_ID=0
