# Dfns API credentials
DFNS_BASE_URL=https://api.dfns.io
DFNS_ORG_ID=your-dfns-org-id
DFNS_AUTH_TOKEN=your-dfns-auth-token
DFNS_CRED_ID=your-dfns-credential-id
DFNS_PRIVATE_KEY_PATH=/path/to/dfns-private-key.pem

# Source wallet with USDC balance on Sepolia
DFNS_WALLET_ID=wa-xxxxx

# Optional: destination wallet (created dynamically if not set)
# DFNS_DEST_WALLET_ID=wa-xxxxx

# Sepolia RPC
NETWORK_HOST=https://ethereum-sepolia-rpc.publicnode.com
